<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /go/

    # Do not redirect if the file or directory exists
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d

    # Route everything else to index.php?slug=...
    RewriteRule ^(.*)$ index.php?slug=$1 [L,QSA]
</IfModule>
